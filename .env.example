# =============================================================================
# Legal Research AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------

# OpenAI API Key (optional - used as fallback LLM if Ollama is unavailable)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Tavily Search API Key (recommended for best RAG-quality web search results)
# Free tier available: https://tavily.com
# If not set, falls back to DuckDuckGo HTML scraping (no key needed)
TAVILY_API_KEY=your_tavily_api_key_here

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------

# Supabase Project URL
# Format: https://your-project-id.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous/Public Key (anon key)
# Found in: Project Settings > API > Project API keys
SUPABASE_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (optional - for admin operations)
# WARNING: Keep this secret! It bypasses Row Level Security
# Found in: Project Settings > API > Project API keys
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Ollama Configuration
# -----------------------------------------------------------------------------

# Ollama API Base URL
# Local: http://localhost:11434
# Docker (host.docker.internal): http://host.docker.internal:11434
# Docker (separate container): http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Model Name
# Options: llama3.1:8b, llama2, mistral, etc.
# Run 'ollama list' to see available models
OLLAMA_MODEL=llama3.1:8b

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Application Name
APP_NAME=Legal Research AI API

# Debug Mode (keep False for deployment)
DEBUG=False

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# JWT Secret Key (generate a secure random string for production)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# JWT Algorithm
JWT_ALGORITHM=HS256

# JWT Token Expiration (in minutes)
JWT_EXPIRATION_MINUTES=1440

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------

# Allowed CORS Origins (comma-separated)
# Development: http://localhost:3000,http://localhost:5173
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend API URL
# Used by the Next.js frontend at build and runtime
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database Configuration (if using additional databases)
# -----------------------------------------------------------------------------

# PostgreSQL connection (if needed beyond Supabase)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
